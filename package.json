{
  "name": "agentic-test-automation",
  "version": "3.0.0",
  "private": true,
  "description": "Agentic Test Automation — capture resilient locators and turn natural-language flows into self-healing Playwright tests, cross-browser and cross-OS",
  "main": "dist/index.js",
  "keywords": [
    "agentic",
    "test-automation",
    "ai",
    "nlp",
    "playwright",
    "self-healing",
    "element-tracking",
    "xpath",
    "css-selector",
    "electron"
  ],
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adarsh7892368289-ai/agentic-test-automation.git"
  },
  "bugs": {
    "url": "https://github.com/adarsh7892368289-ai/agentic-test-automation/issues"
  },
  "homepage": "https://github.com/adarsh7892368289-ai/agentic-test-automation#readme",
  "license": "MIT",
  "scripts": {
    "start": "concurrently \"npm run watch:bundle\" \"npm run watch:main\" \"npm run watch:renderer\" \"electron .\"",
    "watch:bundle": "webpack --config webpack.bundle.config.js --watch",
    "watch:main": "webpack --config webpack.main.config.js --watch",
    "watch:renderer": "webpack --config webpack.renderer.config.js --watch",
    "build:bundle": "webpack --config webpack.bundle.config.js",
    "build:main": "webpack --config webpack.main.config.js",
    "build:renderer": "webpack --config webpack.renderer.config.js",
    "build:mcp": "webpack --config webpack.mcp.config.js",
    "build": "npm run build:bundle && npm run build:main && npm run build:renderer && npm run build:mcp",
    "smoke-test": "electron . --smoke-test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run test/unit",
    "test:jsdom": "vitest run test/jsdom",
    "test:integration": "vitest run test/integration",
    "test:coverage": "vitest run --coverage",
    "lint": "cross-env ESLINT_USE_FLAT_CONFIG=false eslint src/",
    "format": "prettier --write \"src/**/*.{js,css}\"",
    "dist": "npm run build && electron-builder --publish never",
    "dist:win": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:linux": "npm run build && electron-builder --linux --publish never",
    "install:browsers": "playwright install chromium firefox webkit",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "electron-log": "^5.1.2",
    "playwright": "^1.48.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@electron/fuses": "^1.8.0",
    "@vitest/coverage-v8": "^4.1.8",
    "babel-loader": "^10.0.0",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^13.0.1",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^25.0.1",
    "prettier": "^3.6.2",
    "style-loader": "^4.0.0",
    "vitest": "^4.1.8",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1"
  }
}
